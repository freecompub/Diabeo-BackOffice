generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  DOCTOR
  NURSE
  VIEWER
}

enum DiabetesType {
  TYPE1
  TYPE2
  GESTATIONAL
  OTHER
}

// ─── User ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          Role      @default(VIEWER)
  mfaSecret     String?
  mfaEnabled    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patients          Patient[]
  createdConfigs    InsulinConfig[] @relation("CreatedBy")
  validatedConfigs  InsulinConfig[] @relation("ValidatedBy")
  auditLogs         AuditLog[]
  sessions          Session[]
  accounts          Account[]

  @@map("users")
}

// ─── Account (NextAuth v5 — OAuth) ──────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ─── Session (NextAuth v5) ──────────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── VerificationToken (NextAuth v5) ────────────────────

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Patient ─────────────────────────────────────────────

model Patient {
  id            String       @id @default(cuid())
  pseudonymId   String       @unique
  encryptedData Bytes
  diabetesType  DiabetesType
  doctorId      String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  doctor         User            @relation(fields: [doctorId], references: [id])
  insulinConfigs InsulinConfig[]

  @@index([doctorId, deletedAt])
  @@index([deletedAt])
  @@map("patients")
}

// ─── InsulinConfig ───────────────────────────────────────

model InsulinConfig {
  id                String    @id @default(cuid())
  patientId         String
  createdById       String
  sensitivityRatios Json
  carbRatios        Json
  basalRates        Json
  targetGlucose     Json
  maxBolus          Float     @default(25)
  isActive          Boolean   @default(false)
  validatedById     String?
  validatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  patient     Patient @relation(fields: [patientId], references: [id])
  createdBy   User    @relation("CreatedBy", fields: [createdById], references: [id])
  validatedBy User?   @relation("ValidatedBy", fields: [validatedById], references: [id])

  @@index([patientId, isActive])
  @@index([isActive])
  @@map("insulin_configs")
}

// ─── AuditLog (immuable) ─────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([resource, resourceId, createdAt])
  @@map("audit_logs")
}
