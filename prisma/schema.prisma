model DiabetesEvent {
  id                   String              @id @default(uuid())
  patientId            Int                 @map("patient_id")
  eventDate            DateTime            @map("event_date") @db.Timestamptz()
  eventTypes           DiabetesEventType[] @map("event_types")
  glycemiaValue        Decimal?            @map("glycemia_value") @db.Decimal(6, 2)
  carbohydrates        Decimal?            @db.Decimal(6, 2)
  bolusDose            Decimal?            @map("bolus_dose") @db.Decimal(5, 2)
  basalDose            Decimal?            @map("basal_dose") @db.Decimal(5, 2)
  activityType         String?             @map("activity_type") @db.VarChar(20)
  activityDuration     Int?                @map("activity_duration") // minutes
  /// Groupe 6 Batch 1 (US-2059) — métriques détaillées physicalActivity.
  /// Tous optionnels : une entrée manuelle ne renseigne souvent que
  /// `activityType` + `activityDuration`. Les capteurs (US-2060/2061)
  /// fournissent un sous-ensemble.
  activityIntensity    ActivityIntensity?  @map("activity_intensity")
  activitySteps        Int?                @map("activity_steps")
  activityDistanceM    Int?                @map("activity_distance_m") // mètres
  activityCalories     Int?                @map("activity_calories") // kcal
  activityHeartRateAvg Int?                @map("activity_heart_rate_avg") // bpm
  /// Groupe 6 Batch 1 (US-2060/2061) — provenance + dedup mobile sync.
  /// `externalSyncId` est l'UUID que HealthKit / Google Fit attribue à
  /// chaque sample. Couplé à `activitySource` il forme la clé unique
  /// de dedup quand l'app iOS/Android re-pousse le même historique.
  /// NEW-M6 (review PR #407) — pas de @default : c'est le service qui
  /// pose explicitement la valeur (`manual` à la création, valeur enum
  /// pour bulkSync). Évite la pollution cross-domain (events non
  /// physicalActivity) lors d'inserts directs.
  activitySource       ActivitySource?     @map("activity_source")
  externalSyncId       String?             @map("external_sync_id") @db.VarChar(128)
  contextType          String?             @map("context_type") @db.VarChar(20)
  weight               Decimal?            @db.Decimal(5, 2)
  hba1c                Decimal?            @db.Decimal(5, 2)
  ketones              Decimal?            @db.Decimal(5, 2)
  systolicPressure     Int?                @map("systolic_pressure") @db.SmallInt
  diastolicPressure    Int?                @map("diastolic_pressure") @db.SmallInt
  comment              String?
  /// US-2053 — Validation soignant. `validatedBy` = User.id (NURSE+), null
  /// si l'event n'a pas (encore) été revu par un PS.
  validatedAt          DateTime?           @map("validated_at") @db.Timestamptz()
  validatedBy          Int?                @map("validated_by")
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz()

  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  validator  User?       @relation("DiabetesEventValidator", fields: [validatedBy], references: [id], onDelete: SetNull)
  /// US-2057 — Photos repas attachées à un event de type insulinMeal.
  mealPhotos MealPhoto[]

  @@index([patientId, eventDate])
  /// US-2053 — index pour le listing "meals à valider" (validatedAt = null).
  @@index([patientId, validatedAt])
  /// Groupe 6 Batch 1 (US-2060/2061) — dedup mobile sync (partial unique
  /// via migration SQL : `WHERE external_sync_id IS NOT NULL`).
  @@index([activitySource, externalSyncId])
  @@map("diabetes_events")
}

