generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, pg_trgm]
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum Role {
  ADMIN
  DOCTOR
  NURSE
  VIEWER
}

enum Pathology {
  DT1
  DT2
  GD
}

enum Sex {
  M
  F
  X
}

/// US-2026 — Statut de qualite de l'INS (Identite Nationale Sante)
/// conforme Referentiel INS ANS v3 §4.1.
///
///   - `saisi_non_verifie` : INS saisi manuellement (PS ou patient), format
///                           Luhn-97 valide mais NON verifie aupres du
///                           Teleservice INSi. **Interdiction de partage
///                           hors-Diabeo** (DMP, MSSante, FHIR, factures
///                           DGFiP) — V1 procurement non debloque.
///   - `insi_recupere`     : Recupere via TeleserviceInsi (V2 US-2126).
///                           Identitovigilance pleine.
///   - `insi_verifie`      : Verifie via TeleserviceInsi en complement
///                           saisie manuelle (V2 US-2126).
///   - `rejete_traits_incoherent` : INS rejete par INSi pour incoherence
///                                  traits (V2 — pour audit).
enum InsQualityStatus {
  saisi_non_verifie
  insi_recupere
  insi_verifie
  rejete_traits_incoherent
}

enum Language {
  fr
  en
  ar
}

enum DayMomentType {
  morning
  noon
  evening
  night
  custom
}

enum InsulinDeliveryMethod {
  pump
  manual
}

enum TreatmentType {
  fgm
  pump
  insulin_pump
  glp1
}

enum BasalConfigType {
  pump
  single_injection
  split_injection
}

enum GlucoseTargetPreset {
  standard
  tight
  pediatric
  elderly
  custom
}

enum AdjustableParameter {
  basalRate
  insulinSensitivityFactor
  insulinToCarbRatio
}

enum AdjustmentReason {
  basalTooLow
  basalTooHigh
  basalCorrect
  isfTooLow
  isfTooHigh
  isfCorrect
  icrTooLow
  icrTooHigh
  icrCorrect
  insufficientData
}

enum ConfidenceLevel {
