  medium
  high
}

enum ProposalStatus {
  pending
  accepted
  rejected
  expired
}

enum DeviceCategory {
  glucometer
  cgm
  insulinPump
  insulinPen
  healthApp
}

enum DocumentCategory {
  general
  forDoctor
  personal
  prescription
  labResults
  other
}

enum PushPlatform {
  ios
  android
  web
}

enum PushNotifStatus {
  pending
