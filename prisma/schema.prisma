/// US-2113 — Devise par pays. Référence ISO 4217 (EUR pour FR, DZD pour DZ).
/// `exchangeRate` est la parité vers la devise de référence (EUR ; 1.0 pour EUR).
/// Pas de PHI ; configuration publique gérée par ADMIN, lue par DOCTOR/NURSE.
model CountryCurrency {
  id           Int      @id @default(autoincrement())
  countryCode  String   @map("country_code") @db.Char(2) // ISO 3166-1 alpha-2 : FR, DZ
  currencyCode String   @map("currency_code") @db.Char(3) // ISO 4217 : EUR, DZD
  symbol       String   @db.VarChar(8) // €, DA
  exchangeRate Decimal  @map("exchange_rate") @db.Decimal(12, 6) // parité → EUR (référence)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  createdBy    Int?     @map("created_by")

  creator User? @relation("CountryCurrencyCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([countryCode, currencyCode])
  @@index([countryCode, isActive])
  @@map("country_currencies")
}

/// US-2114 — Règles fiscales par pays. `taxType` ∈ {VAT, INCOME_TAX,
/// CORPORATE_TAX, SOCIAL_CONTRIBUTION}. Date-bornée pour gérer les
/// changements de taux (ex. TVA FR 19.6 → 20.0 au 01/01/2014).
/// Pas de PHI.
model CountryTaxRule {
  id           Int       @id @default(autoincrement())
  countryCode  String    @map("country_code") @db.Char(2)
  taxType      String    @map("tax_type") @db.VarChar(30)
  baseRate     Decimal   @map("base_rate") @db.Decimal(6, 4) // 0.2000 = 20.00 %
  description  String?   @db.VarChar(500)
  appliesFrom  DateTime  @map("applies_from") @db.Date
  appliesUntil DateTime? @map("applies_until") @db.Date
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  createdBy    Int?      @map("created_by")

  creator User? @relation("CountryTaxRuleCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  /// Une seule règle active à la fois pour (pays, type, date début).
  @@unique([countryCode, taxType, appliesFrom])
  @@index([countryCode, taxType, isActive])
  @@map("country_tax_rules")
}

/// US-2116 — Référentiel des réglementations santé par pays
/// (HDS, ANS, CNIL FR ; DPSP DZ ; etc.). Strictement référentiel —
/// la conformité opérationnelle reste applicative.
model HealthcareRegulation {
  id             Int       @id @default(autoincrement())
  countryCode    String    @map("country_code") @db.Char(2)
  regulationType String    @map("regulation_type") @db.VarChar(50) // RPPS, ADELI, INS, HDS, RGPD, ...
  title          String    @db.VarChar(200)
  rule           String    @db.Text // texte ou JSON
  references     String?   @db.Text // URL légifrance / DOM, refs normatives
  enforcedFrom   DateTime  @map("enforced_from") @db.Date
  enforcedUntil  DateTime? @map("enforced_until") @db.Date
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  createdBy      Int?      @map("created_by")

  creator User? @relation("HealthcareRegulationCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([countryCode, regulationType, isActive])
  @@map("healthcare_regulations")
}

/// US-2123 — Allowlist des systèmes FHIR tiers approuvés (DPA en place).
/// Toute tentative de PUSH vers `externalSystemUrl` doit matcher un origin
/// présent dans cette table et `isActive = true`. `killSwitchActive = true`
/// sur n'importe quelle ligne désactive instantanément tout PUSH (rejet 503).
model FhirAllowedSystem {
  id               Int      @id @default(autoincrement())
  /// Origin (scheme://host[:port]) — pas de path/query, comparé en strict equality.
  origin           String   @db.VarChar(255)
  /// Description du destinataire pour audit (`DMP Mon Espace Santé`, `EHR Cabinet X`).
  label            String   @db.VarChar(200)
  /// Référence du DPA signé (URL interne ou identifiant document compliance).
  dpaReference     String   @map("dpa_reference") @db.VarChar(500)
  isActive         Boolean  @default(true) @map("is_active")
  killSwitchActive Boolean  @default(false) @map("kill_switch_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  createdBy        Int?     @map("created_by")

  creator User? @relation("FhirAllowedSystemCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([origin])
  @@index([isActive, killSwitchActive])
  @@map("fhir_allowed_systems")
}

/// US-2123 — Ressources FHIR R4 exportées vers un serveur tiers (DMP, EHR,
/// laboratoire, etc.). Le payload contient des données de santé : chiffré
/// AES-256-GCM (base64) comme le reste du repo. Le flux est asynchrone
/// (file de retry) pour résister aux indisponibilités tierces. Feature flag
/// `FHIR_ENABLED` (env) gate l'activation.
model FhirInteroperability {
  id                Int            @id @default(autoincrement())
  patientId         Int?           @map("patient_id")
  resourceType      String         @map("resource_type") @db.VarChar(50) // Patient, Observation, Medication, MedicationRequest, ...
  externalSystemUrl String         @map("external_system_url") @db.VarChar(500)
  fhirResourceId    String?        @map("fhir_resource_id") @db.VarChar(255) // ID retourné par le serveur tiers après PUSH OK
  /// Payload FHIR JSON chiffré (AES-256-GCM ; format IV+TAG+CIPHERTEXT en base64).
  payloadEncrypted  String         @map("payload_encrypted") @db.Text
  syncStatus        FhirSyncStatus @default(pending) @map("sync_status")
  retryCount        Int            @default(0) @map("retry_count")
  nextRetryAt       DateTime?      @map("next_retry_at") @db.Timestamptz()
  lastSyncedAt      DateTime?      @map("last_synced_at") @db.Timestamptz()
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz()
  createdBy         Int?           @map("created_by")

  /// H2 — onDelete SetNull preserves the audit trail of PHI exports even when
  /// the patient record is hard-deleted (CNIL/ANS forensic retention).
  patient  Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  creator  User?         @relation("FhirInteroperabilityCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  syncLogs FhirSyncLog[]

  @@index([syncStatus, nextRetryAt])
  @@index([patientId, resourceType])
  @@index([resourceType, externalSystemUrl])
  @@map("fhir_interoperability")
}

/// US-2123 — Journal des tentatives PUSH/PULL/TRANSFORM par ressource.
/// Immuable (un log par tentative). Pas de PHI dans `errorMessage` (le
/// service tronque/anonymise les corps de réponse).
model FhirSyncLog {
  id           Int      @id @default(autoincrement())
  interopId    Int      @map("interop_id")
  action       String   @db.VarChar(30) // PUSH, PULL, TRANSFORM, RETRY
  httpStatus   Int?     @map("http_status")
  errorMessage String?  @map("error_message") @db.Text
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  interop FhirInteroperability @relation(fields: [interopId], references: [id], onDelete: Cascade)

  @@index([interopId, createdAt])
  @@map("fhir_sync_logs")
}

enum FhirSyncStatus {
  pending
  synced
  failed
  stale

  @@map("fhir_sync_status")
}

// ─────────────────────────────────────────────────────────────
// Groupe 10 Mirror V1 — Batch A : Config urgences avancée
// ─────────────────────────────────────────────────────────────

/// US-2221 — Hub versioning partagé pour les configurations patient
/// (contacts urgence, escalation rules, alert thresholds). Append-only :
/// chaque changement crée une nouvelle ligne avec `validFrom` set, l'ancienne
/// passe `validTo`. Immuable après insertion (trigger PostgreSQL).
///
/// `configSnapshot` = JSON dénormalisé de la config au moment du change,
/// utilisé par l'API history pour reconstituer un état passé sans dépendre
/// de l'évolution future des tables filles.
model ConfigVersion {
  id             Int                 @id @default(autoincrement())
  /// C3-NEW (re-review) — nullable for RGPD Art. 17 hard-delete compatibility :
  /// patient deletion sets this to NULL, preserving config history as orphan
  /// (audit-friendly) without violating the append-only `no_delete` trigger.
  patientId      Int?                @map("patient_id")
  configType     ConfigVersionType   @map("config_type")
  version        Int
  configSnapshot Json                @map("config_snapshot")
  validFrom      DateTime            @default(now()) @map("valid_from") @db.Timestamptz()
  validTo        DateTime?           @map("valid_to") @db.Timestamptz()
  status         ConfigVersionStatus @default(active)
  createdBy      Int                 @map("created_by")
  validatedBy    Int?                @map("validated_by")
  validatedAt    DateTime?           @map("validated_at") @db.Timestamptz()
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  patient             Patient?             @relation(fields: [patientId], references: [id], onDelete: SetNull)
  creator             User                 @relation("ConfigVersionCreator", fields: [createdBy], references: [id])
  validator           User?                @relation("ConfigVersionValidator", fields: [validatedBy], references: [id], onDelete: SetNull)
  contacts            EmergencyContact[]
  escalationRules     EscalationRule[]
  pediatricCaregivers PediatricCaregiver[]

  @@unique([patientId, configType, version])
  @@index([patientId, configType, validFrom])
  @@index([status, configType])
  @@map("config_versions")
}

enum ConfigVersionType {
  emergency_contacts
  escalation_rules
  alert_thresholds
  /// US-2233 — Mode pédiatrique (multi-aidants, validation DOCTOR).
  pediatric_mode
  /// US-2234 — Mode Ramadan (dates jeûne, sahur/iftar, ISF/ICR adaptés).
  ramadan_mode
  /// US-2235 — Mode voyage (fuseau horaire, protocole basal).
  travel_mode
  /// US-2240 — Partage tiers (école, EHPAD, cabinet externe). Validation
  /// médicale DOCTOR requise avant activation.
  third_party_share
  /// US-2242 — Notifications partagées : matrice alertType × caregivers.
  /// DOCTOR configure quels aidants reçoivent quelles alertes.
  shared_notifications

  @@map("config_version_type")
}

enum ConfigVersionStatus {
  /// US-2221 — Live, en vigueur.
  active
  /// Remplacée par une version ultérieure.
  superseded
  /// Archivée (purgée du listing actif).
  archived

  @@map("config_version_status")
}

/// US-2218 — Contacts d'urgence (max 5 par patient) joignables en cas
/// d'alerte critique. `name` et `phone` chiffrés AES-256-GCM (PHI).
model EmergencyContact {
  id             Int      @id @default(autoincrement())
  patientId      Int      @map("patient_id")
  versionId      Int      @map("version_id")
  rank           Int
  /// AES-256-GCM (base64).
  nameEncrypted  String   @map("name_encrypted") @db.Text
  /// AES-256-GCM (base64).
  phoneEncrypted String   @map("phone_encrypted") @db.Text
  relationship   String   @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  configVersion ConfigVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([patientId, rank, isActive])
  @@map("emergency_contacts")
}

/// US-2233 — Aidant pédiatrique (parent, école, baby-sitter, etc.).
/// PHI : `name` et `phone` chiffrés AES-256-GCM (base64). FK ConfigVersion
/// pour versioning : la création d'une nouvelle version pédiatrique crée
/// une nouvelle ligne par aidant lié à la nouvelle `versionId`.
model PediatricCaregiver {
  id              Int      @id @default(autoincrement())
  patientId       Int      @map("patient_id")
  versionId       Int      @map("version_id")
  rank            Int
  /// AES-256-GCM (base64).
  nameEncrypted   String   @map("name_encrypted") @db.Text
  /// AES-256-GCM (base64).
  phoneEncrypted  String   @map("phone_encrypted") @db.Text
  relationship    String   @db.VarChar(50)
  /// Permissions : "read" | "write" | "propose" (caregivers may propose
  /// adjustments but never directly mutate — HAS pédiatrique / ISPAD 2022).
  permissionLevel String   @map("permission_level") @db.VarChar(20)
  /// M2 (healthcare audit) — historical "active" flag retained for parity
  /// with `emergency_contacts.is_active` ; truth lives in
  /// `config_versions.status` (filter via `findFirst({ status: active })`).
  /// Never flipped on supersede ; do NOT query raw SQL on this column.
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  configVersion ConfigVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  /// H3 (re-review C, post-merge) — UNIQUE(version_id, rank) couples with
  /// the CHECK constraint `rank BETWEEN 1 AND 5` to enforce MAX_CAREGIVERS=5
  /// at the DB layer (defense in depth ; service-level validator stays).
  @@unique([versionId, rank])
  @@index([patientId, rank, isActive])
  /// M4 (healthcare audit) — index FK so cascade-include joins from
  /// ConfigVersion don't sequential-scan at scale.
  @@index([versionId])
  @@map("pediatric_caregivers")
}

/// US-2219 — Règles d'escalade urgence (chaîne patient → contact → médecin
/// → SAMU). `delayMinutes` = délai d'attente avant escalade au target suivant.
model EscalationRule {
  id           Int                  @id @default(autoincrement())
  patientId    Int                  @map("patient_id")
  versionId    Int                  @map("version_id")
  priority     Int
  targetType   EscalationTargetType @map("target_type")
  /// FK vers EmergencyContact.id (si targetType=contact) ou User.id (si targetType=doctor).
  /// Null pour SAMU (pas de FK).
  targetId     Int?                 @map("target_id")
  delayMinutes Int                  @default(15) @map("delay_minutes")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz()

  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  configVersion ConfigVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([patientId, priority])
  @@map("escalation_rules")
}

enum EscalationTargetType {
  contact
  doctor
  samu

  @@map("escalation_target_type")
}

/// US-2220 — Bibliothèque de templates de seuils glycémiques par profil
/// patient (T1 adulte stable, T1 ado, T2, gestationnel, pédiatrique).
/// `glucose*Mgdl` en mg/dL. Cabinet-scoped via `organizationId`.
model AlertThresholdTemplate {
  id                  Int      @id @default(autoincrement())
  organizationId      Int      @map("organization_id")
  profileType         String   @map("profile_type") @db.VarChar(50)
  name                String   @db.VarChar(100)
  glucoseLowMgdl      Decimal  @map("glucose_low_mgdl") @db.Decimal(6, 2)
  glucoseHighMgdl     Decimal  @map("glucose_high_mgdl") @db.Decimal(6, 2)
  glucoseVeryLowMgdl  Decimal  @map("glucose_very_low_mgdl") @db.Decimal(6, 2)
  glucoseVeryHighMgdl Decimal  @map("glucose_very_high_mgdl") @db.Decimal(6, 2)
  alertOnHypo         Boolean  @default(true) @map("alert_on_hypo")
  cooldownMinutes     Int      @default(30) @map("cooldown_minutes")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  createdBy           Int?     @map("created_by")

  organization HealthcareService @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User?             @relation("AlertThresholdTemplateCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([organizationId, profileType, name])
  @@index([organizationId, isActive])
  @@map("alert_threshold_templates")
}

// ─────────────────────────────────────────────────────────────
// Groupe 10 Mirror V1 — Batch B : Analytics urgences
// ─────────────────────────────────────────────────────────────

/// US-2227 — Cache trimestriel des métriques d'urgence par patient.
/// Recomputed nightly via BullMQ job + on-demand refresh par DOCTOR.
model PatientMonitoringMetrics {
  id              Int      @id @default(autoincrement())
  patientId       Int      @map("patient_id")
  /// Format `YYYY-Qn` (e.g. `2026-Q2`).
  quarter         String   @db.VarChar(7)
  hypoCount       Int      @default(0) @map("hypo_count")
  severeHypoCount Int      @default(0) @map("severe_hypo_count")
  dkaCount        Int      @default(0) @map("dka_count")
  avgDurationMin  Decimal? @map("avg_duration_min") @db.Decimal(6, 1)
  topHourOfDay    Int?     @map("top_hour_of_day")
  metricsJson     Json     @map("metrics_json")
  computedAt      DateTime @default(now()) @map("computed_at") @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, quarter])
  @@index([computedAt])
  @@map("patient_monitoring_metrics")
}

/// US-2228 — Snapshot quotidien des KPIs cohorte (taux hypos sévères pour
/// 1000 jours-patient, incidence DKA, benchmarks nationaux anonymisés).
model CohortAnalyticsSnapshot {
  id                Int      @id @default(autoincrement())
  organizationId    Int      @map("organization_id")
  snapshotDate      DateTime @map("snapshot_date") @db.Date
  patientCount      Int      @map("patient_count")
  severeHypoRate    Decimal  @map("severe_hypo_rate") @db.Decimal(7, 2)
  dkaIncidence      Decimal  @map("dka_incidence") @db.Decimal(7, 2)
  nationalBenchmark Json     @map("national_benchmark")
  stratification    Json
  computedAt        DateTime @default(now()) @map("computed_at") @db.Timestamptz()

  organization HealthcareService @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, snapshotDate])
  @@index([snapshotDate])
  @@map("cohort_analytics_snapshots")
}

/// US-2229 — Score de risque patient agrégé (0-100). Recomputed hebdo via
/// BullMQ job. Trigger une alerte au DOCTOR si score > 70 (niveau HIGH/CRITICAL).
/// `contributingFactors` = explicabilité du score (rule-based, pas ML pour MVP).
model PatientRiskScore {
  id                  Int       @id @default(autoincrement())
  patientId           Int       @unique @map("patient_id")
  riskScore           Int       @map("risk_score") @db.SmallInt
  riskLevel           RiskLevel @map("risk_level")
  recentHypoCount     Int       @map("recent_hypo_count")
  declarationRatio    Decimal   @map("declaration_ratio") @db.Decimal(4, 2)
  dkaHistory          Boolean   @default(false) @map("dka_history")
  contributingFactors Json      @map("contributing_factors")
  flaggedAt           DateTime? @map("flagged_at") @db.Timestamptz()
  acknowledgedBy      Int?      @map("acknowledged_by")
  acknowledgedAt      DateTime? @map("acknowledged_at") @db.Timestamptz()
  computedAt          DateTime  @default(now()) @map("computed_at") @db.Timestamptz()

  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  acknowledger User?   @relation("PatientRiskScoreAcknowledger", fields: [acknowledgedBy], references: [id], onDelete: SetNull)

  @@index([riskLevel, computedAt])
  @@map("patient_risk_scores")
}

enum RiskLevel {
  low
  medium
  high
  critical

  @@map("risk_level")
}

// ═══════════════════════════════════════════════════════════════
// 17. DOMAINE FACTURATION — Groupe 7 Batch 1 (US-2103 / 2105 / 2107)
// ═══════════════════════════════════════════════════════════════
//
// Modèle facture immuable post-issuance, numérotation gap-less per-
// country/year, machine d'états explicite. Aucune PHI dans le modèle
// (le snapshot patient/issuer est chiffré au service layer côté V1+).

/// US-2107 — Cycle de vie facture, machine d'états explicite.
///
/// Transitions autorisées (FSM appliquée au trigger PG + service) :
///   draft     → issued | cancelled
///   issued    → paid | cancelled
///   paid      → refunded
///   cancelled = terminal
///   refunded  = terminal
enum InvoiceStatus {
  draft
  issued
  paid
  cancelled
  refunded

  @@map("invoice_status")
}

enum PaymentMethod {
  stripe
  bank_transfer
  cash
  other

  @@map("payment_method")
}

/// US-2103 / US-2105 / US-2107 — Facture cabinet, immuable post-issuance.
///
/// Numérotation `number` : NULL en draft, format `FR-2026-000001` dès
/// l'issuance (`InvoiceSequence` row-locked FOR UPDATE pour gap-less).
///
/// Immuabilité enforced par trigger `enforce_invoice_immutability` :
///  - `number`, `total_cents`, `tax_cents`, `currency`, `country_code`,
///    `cabinet_id`, `patient_id`, `issued_at`, `pdf_hash`, snapshots →
///    locked dès status ≠ draft.
///  - `status` transitions limitées à la FSM ci-dessus.
///  - DELETE bloqué dès status ≠ draft (utiliser cancel transition).
///
/// Snapshots `issuer_snapshot` / `customer_snapshot` : copie immutable
/// du cabinet (raison sociale, adresse, SIRET) et du client (nom,
/// pseudonymisé HMAC pour patients) au moment de l'issuance. Garantit
/// que des modifs ultérieures (changement d'adresse cabinet, soft-delete
/// patient) n'altèrent pas une facture passée — exigence anti-fraude
/// + obligation comptable FR (DGFiP).
model Invoice {
  id                    Int            @id @default(autoincrement())
  /// Numéro séquentiel `<country>-<year>-<6digits>`. NULL en draft.
  number                String?        @unique @db.VarChar(30)
  countryCode           String         @map("country_code") @db.Char(2)
  cabinetId             Int            @map("cabinet_id")
  /// Optionnel : facture patient (US-2103) ou cabinet-interne.
  patientId             Int?           @map("patient_id")
  /// Montants entiers en cents (anti floating-point). EUR/DZD.
  /// `total_cents` = HT + taxe = sum(items.line_total_cents)
  /// `tax_cents`   = sum(items.tax_cents)
  totalCents            Int            @map("total_cents")
  taxCents              Int            @map("tax_cents")
  /// ISO 4217 (EUR | DZD) — validé via CountryCurrency au service.
  currency              String         @db.Char(3)
  status                InvoiceStatus  @default(draft)
  paymentMethod         PaymentMethod? @map("payment_method")
  /// Renseigné après webhook Stripe US-2106 (Batch 3).
  stripePaymentIntentId String?        @map("stripe_payment_intent_id") @db.VarChar(50)
  /// PDF généré US-2102 (Batch 2) — URL S3 OVH + SHA-256 intégrité.
  pdfUrl                String?        @map("pdf_url") @db.VarChar(500)
  pdfHash               String?        @map("pdf_hash") @db.Char(64)
  /// Snapshot cabinet au moment issuance — JSON arbitraire :
  /// { name, addressLine1, postalCode, city, country, siret?, tva? }.
  issuerSnapshot        Json?          @map("issuer_snapshot")
  /// Snapshot client au moment issuance. Pour patients : nom pseudonymisé
  /// (HMAC) ou chiffré AES selon politique RGPD V1+. MVP : null si pas patient.
  customerSnapshot      Json?          @map("customer_snapshot")
  issuedAt              DateTime?      @map("issued_at") @db.Timestamptz()
  paidAt                DateTime?      @map("paid_at") @db.Timestamptz()
  cancelledAt           DateTime?      @map("cancelled_at") @db.Timestamptz()
  refundedAt            DateTime?      @map("refunded_at") @db.Timestamptz()
  createdBy             Int            @map("created_by")
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  cabinet   HealthcareService @relation(fields: [cabinetId], references: [id], onDelete: Restrict)
  patient   Patient?          @relation(fields: [patientId], references: [id], onDelete: SetNull)
  creator   User              @relation("InvoiceCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  items     InvoiceItem[]
  /// US-2108 — Journal des relances envoyees (cron J+7/15/30).
  reminders InvoiceReminder[]

  /// Unicité globale du numéro garantie par `@unique` sur `number`,
  /// mais `(countryCode, number)` garde la sémantique métier explicite.
  @@unique([countryCode, number])
  @@index([cabinetId, status, issuedAt(sort: Desc)])
  @@index([patientId, issuedAt(sort: Desc)])
  @@index([status, issuedAt])
  /// FK Restrict : index sur createdBy pour les jointures admin.
  @@index([createdBy])
  @@map("invoices")
}

/// US-2108 — Relances factures automatiques (Batch 4 Facturation).
///
/// Cron J+7 / J+15 / J+30 via Resend. Idempotent : `@@unique([invoiceId,
/// step])` empeche envoi double si cron rejoue le meme jour.
enum InvoiceReminderStep {
  /// J+7 amicale "facture en attente".
  step_7
  /// J+15 ferme "deuxieme relance".
  step_15
  /// J+30 finale "derniere relance avant procedure".
  step_30

  @@map("invoice_reminder_step")
}

enum InvoiceReminderStatus {
  /// Email envoye (Resend OK).
  sent
  /// Resend a echoue (erreur reseau, quota, etc.).
  failed
  /// Pas d'email destinataire (invoice cabinet-interne sans patient).
  skipped

  @@map("invoice_reminder_status")
}

model InvoiceReminder {
  id             Int                   @id @default(autoincrement())
  invoiceId      Int                   @map("invoice_id")
  step           InvoiceReminderStep
  sentAt         DateTime              @default(now()) @map("sent_at") @db.Timestamptz()
  status         InvoiceReminderStatus @default(sent)
  /// Email destinataire chiffre AES-256-GCM (base64) — forensique sans
  /// exposer mail patient en clair en BDD. Optional car certaines step
  /// `skipped` arrivent avant qu'on ait pu dechiffrer.
  sentToEnc      String?               @map("sent_to_enc")
  /// ID Resend (data.id) — debug rebonds via Resend dashboard.
  emailMessageId String?               @map("email_message_id") @db.VarChar(100)
  /// Message d'erreur Resend (pas de PHI — code/timeout). Cap 500 chars.
  errorMessage   String?               @map("error_message") @db.VarChar(500)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, step])
  @@index([invoiceId, sentAt(sort: Desc)])
  @@index([sentAt(sort: Desc)])
  @@map("invoice_reminders")
}

/// Ligne de facture. Verrouillée en immutabilité avec l'Invoice parente
/// dès que invoice.status ≠ draft (trigger PG block_invoice_items_after_issued).
model InvoiceItem {
  id                Int      @id @default(autoincrement())
  invoiceId         Int      @map("invoice_id")
  description       String   @db.VarChar(500)
  /// Quantité décimale (consultation 0.5h, forfait, etc.).
  quantity          Decimal  @db.Decimal(10, 3)
  /// Prix unitaire HT en cents.
  unitPriceCents    Int      @map("unit_price_cents")
  /// Taux TVA fractionnaire (0.2000 = 20%). Snapshot CountryTaxRule.
  taxRate           Decimal  @map("tax_rate") @db.Decimal(6, 4)
  /// `tax_cents`        = round(quantity × unit_price_cents × tax_rate)
  /// `line_total_cents` = round(quantity × unit_price_cents) + tax_cents
  taxCents          Int      @map("tax_cents")
  lineTotalCents    Int      @map("line_total_cents")
  /// US-2072 — Lien optionnel acte téléconsultation (1:1).
  teleconsultActeId Int?     @unique @map("teleconsult_acte_id")
  /// Ordre d'affichage sur la facture rendue.
  position          Int
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  invoice         Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  teleconsultActe TeleconsultationActe? @relation(fields: [teleconsultActeId], references: [id], onDelete: SetNull)

  @@index([invoiceId, position])
  @@map("invoice_items")
}

/// US-2105 — Compteur séquentiel par (country, year).
///
/// Anti-fraude : numérotation gap-less garantie par
///   1. INSERT … ON CONFLICT DO NOTHING (create row si manquante)
///   2. SELECT last_number … FOR UPDATE (row lock — sérialise les
///      issuances concurrentes du même pays/année)
///   3. UPDATE last_number = last_number + 1
///   4. INSERT invoice avec `number = format(countryCode, year, next)`
///   5. Commit
///
/// Si l'INSERT invoice échoue, ROLLBACK rétablit `last_number` au
/// précédent → pas de gap, pas de doublon. Conforme DGFiP FR
/// (numérotation chronologique continue, art. 242 nonies A CGI).
model InvoiceSequence {
  id          Int      @id @default(autoincrement())
  countryCode String   @map("country_code") @db.Char(2)
  year        Int
  lastNumber  Int      @default(0) @map("last_number")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([countryCode, year])
  @@map("invoice_sequences")
}

// ═══════════════════════════════════════════════════════════════
// 18. DOMAINE ADMIN & OPS — Groupe 9 (US-2137 / 2147 / 2150)
// ═══════════════════════════════════════════════════════════════

/// US-2137 — Sévérité d'une violation données personnelles (échelle CNIL).
/// `high` ou `critical` déclenche l'obligation de notification à la CNIL
/// dans les 72h (art. 33 RGPD).
enum DataBreachSeverity {
  low
  medium
  high
  critical

  @@map("data_breach_severity")
}

/// US-2137 — Machine d'états workflow notification breach CNIL.
///
///   draft → under_assessment → notified_cnil → notified_users → closed
///   draft → closed (false_alarm)
///   under_assessment → closed (non_qualifying)
enum DataBreachStatus {
  draft
  under_assessment
  notified_cnil
  notified_users
  closed

  @@map("data_breach_status")
}

/// US-2137 — Registre des violations de données personnelles (RGPD Art. 33).
///
/// Workflow CNIL :
///  1. Détection → `draft`
///  2. Évaluation (DPO, juriste) → `under_assessment`
///  3. Si severity ≥ high, notification CNIL dans 72h → `notified_cnil`
///     (timer démarré à `detectedAt`).
///  4. Si risque élevé pour les personnes, notification users → `notified_users`
///  5. Clôture une fois remédiation appliquée → `closed`
///
/// Champs sensibles (`description`, `remediation`, `cnilCaseNumber`)
/// chiffrés AES-256-GCM au service layer.
model DataBreach {
  id                 Int                @id @default(autoincrement())
  severity           DataBreachSeverity
  status             DataBreachStatus   @default(draft)
  /// Titre court — pas chiffré pour permettre listing / search.
  ///
  /// **⚠️ NE PAS METTRE DE PHI/PII** : NIRPP, nom patient, email, téléphone.
  /// Utiliser une référence technique (ticket-ID, incident-code). Le service
  /// valide une heuristique anti-PII (15 digits, téléphone FR, email) au declare.
  /// PHI/PII appartient à `description_enc` (chiffré AES-256-GCM).
  title              String             @db.VarChar(200)
  /// Description détaillée (chiffrée AES-256-GCM). Inclut nature exacte
  /// de la fuite, données affectées, vecteur, mesures immédiates.
  descriptionEnc     String?            @map("description_enc")
  /// Plan de remédiation (chiffré). Mis à jour au fil du workflow.
  remediationEnc     String?            @map("remediation_enc")
  /// Numéro de dossier CNIL une fois notifié (chiffré, contient PII métier).
  cnilCaseNumberEnc  String?            @map("cnil_case_number_enc")
  /// Compteur des users notifiés (US art. 34). Pour audit/justification CNIL.
  usersNotifiedCount Int                @default(0) @map("users_notified_count")
  detectedAt         DateTime           @map("detected_at") @db.Timestamptz()
  declaredBy         Int?               @map("declared_by")
  cnilNotifiedAt     DateTime?          @map("cnil_notified_at") @db.Timestamptz()
  usersNotifiedAt    DateTime?          @map("users_notified_at") @db.Timestamptz()
  closedAt           DateTime?          @map("closed_at") @db.Timestamptz()
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  declarer User? @relation("DataBreachDeclarer", fields: [declaredBy], references: [id], onDelete: SetNull)

  @@index([status, severity, detectedAt(sort: Desc)])
  @@index([detectedAt(sort: Desc)])
  /// FK SetNull : index sur declaredBy pour la requête forensique
  /// "violations déclarées par user X".
  @@index([declaredBy])
  @@map("data_breaches")
}

/// US-2076 scope A — Messagerie sécurisée 1↔1 patient↔PS et staff↔staff.
///
/// Approche V1 = REST + polling 60s badge + FCM data-only push (sans
/// WebSocket realtime — reporté V2 sous `US-2076bis`, voir CLAUDE.md
/// archi décision 2026-05-15). Pattern Slack-like adapté HDS.
///
/// Sécurité HDS :
///   - `bodyEncrypted` : corps chiffré AES-256-GCM (IV+TAG+CIPHERTEXT)
///     via `lib/crypto/health-data.ts`. JAMAIS de plaintext en DB.
///   - `conversationKey` : SHA-256(min(uid1,uid2)+":"+max(uid1,uid2)) hex 64,
///     index pour fetch thread + scoping (les deux participants partagent
///     la même clé canonique).
///   - `patientId` : pivot audit US-2268 si message lié à un patient
///     (patient↔PS, ou staff↔staff discutant d'un patient). NULL pour
///     coordination staff pure (sans patient identifié).
///   - `deletedAt` : soft-delete RGPD (Art. 17). Trigger fait DELETE
///     physique sur cascade User.
///   - FK Cascade : suppression user → ses messages purgés. Audit log
///     préservé (immuable par trigger).
///
/// Indexes :
///   - `(toUserId, readAt, createdAt)` : unread count + inbox tri.
///   - `(conversationKey, createdAt DESC)` : fetch d'un thread.
///   - `(patientId)` : pivot US-2268 — events messagerie d'un patient.
model Message {
  id              String    @id @default(cuid())
  /// SHA-256(min(uid1,uid2)+":"+max(uid1,uid2)) hex 64 — canonical hash.
  conversationKey String    @map("conversation_key") @db.VarChar(64)
  fromUserId      Int       @map("from_user_id")
  toUserId        Int       @map("to_user_id")
  /// Corps chiffré AES-256-GCM (IV+TAG+CIPHERTEXT). Bytes natif PostgreSQL.
  bodyEncrypted   Bytes     @map("body_encrypted")
  /// Pivot US-2268 — Patient.id si message contextualise un patient,
  /// NULL pour coordination staff pure sans patient identifié.
  patientId       Int?      @map("patient_id")
  readAt          DateTime? @map("read_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  /// FK Restrict (Prisma H3 / HSA MED-3 review round 3) — empêche
  /// toute DELETE physique raw SQL accidentelle. La suppression user
  /// passe par `deletion.service.ts` qui purge explicitement.
  fromUser User     @relation("MessageSender", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser   User     @relation("MessageRecipient", fields: [toUserId], references: [id], onDelete: Restrict)
  patient  Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  /// Prisma M-1 review round 5 — Index `(toUserId, readAt, createdAt)` retiré
  /// (subsumé par `messages_unread_groupby_idx` partial + `messages_to_thread_recency_idx` partial).
  /// Prisma H1 review round 3 — couvre le `groupBy conversationKey` du
  /// unread aggregate dans `listThreads`. Partial WHERE défini en SQL.
  @@index([toUserId, readAt, conversationKey], map: "messages_unread_groupby_idx")
  /// Fetch d'un thread paginé par cursor `createdAt DESC`.
  @@index([conversationKey, createdAt(sort: Desc)])
  /// Pivot US-2268 — forensique "tous les messages liés au patient X".
  /// Partial WHERE patient_id IS NOT NULL défini en SQL (Prisma 7 ne
  /// supporte pas encore les partial indexes côté schema).
  @@index([patientId])
  /// FK index pour forensique deleted messages (les autres indexes
  /// partials `WHERE deleted_at IS NULL` ne couvrent pas ce cas).
  @@index([fromUserId])
  /// NEW-H1 CR review round 4 — Composite indexes pour DISTINCT ON
  /// listThreads. Permet à PG d'utiliser Index Skip Scan / Merge Append.
  /// Partial WHERE deleted_at IS NULL défini en SQL.
  @@index([fromUserId, conversationKey, createdAt(sort: Desc)], map: "messages_from_thread_recency_idx")
  @@index([toUserId, conversationKey, createdAt(sort: Desc)], map: "messages_to_thread_recency_idx")
  /// Soft-delete RGPD filter. Partial WHERE deleted_at IS NOT NULL en SQL.
  @@index([deletedAt])
  @@map("messages")
}

// ────────────────────────────────────────────────────────────────────────
// US-2506 — Option SMS payante cabinet (V1 mock, real Twilio/OVH V3)
// ────────────────────────────────────────────────────────────────────────

/// US-2506 V1 mock — Statut envoi SMS.
enum SmsStatus {
  /// Real provider OK (Twilio/OVH V3).
  sent
  /// Provider erreur.
  failed
  /// Cabinet `smsEnabled=FALSE` ou `smsCreditBalance=0`.
  skipped
  /// V1 mock explicite — pas de vrai envoi (provider="mock").
  mock

  @@map("sms_status")
}

/// US-2506 V1 mock — Journal envois SMS. V1 = mock provider (status=mock
/// par defaut). V3 = real Twilio/OVH (status=sent/failed). Le mock est
/// utilise par US-2502 pour les rappels RDV J-1.
model SmsLog {
  id                Int       @id @default(autoincrement())
  cabinetId         Int       @map("cabinet_id")
  /// Numero destinataire chiffre AES-256-GCM base64 (defensive vs dump
  /// BDD). Optional pour status='skipped' (avant decryption).
  toEnc             String?   @map("to_enc")
  /// Apercu 120 premiers chars du message (forensique sans plaintext
  /// complet contre leak PHI).
  messageExcerpt    String?   @map("message_excerpt") @db.VarChar(120)
  status            SmsStatus @default(mock)
  /// Provider : 'mock' (V1) | 'twilio' (V3) | 'ovh' (V3).
  provider          String    @default("mock") @db.VarChar(30)
  /// ID Twilio/OVH si real ; UUID mock-* si V1.
  providerMessageId String?   @map("provider_message_id") @db.VarChar(100)
  /// Cout en credits (1 SMS standard = 1 credit V1).
  creditCost        Int       @default(1) @map("credit_cost")
  errorMessage      String?   @map("error_message") @db.VarChar(500)
  sentAt            DateTime  @default(now()) @map("sent_at") @db.Timestamptz()
  /// Contexte d'envoi : 'appointment_reminder' (US-2502) | futurs.
  contextKind       String    @map("context_kind") @db.VarChar(50)

  /// M7 round 2 — Restrict pour préserver l'historique audit SMS forensique
  /// (HealthcareService n'est jamais hard-deleted en pratique, mais CASCADE
  /// silencieux serait dangereux). Cohérent avec `invoices.cabinet_id`.
  cabinet HealthcareService @relation(fields: [cabinetId], references: [id], onDelete: Restrict)

  @@index([cabinetId, sentAt(sort: Desc)])
  @@index([sentAt(sort: Desc)])
  @@map("sms_logs")
}

// ────────────────────────────────────────────────────────────────────────
// US-2502 — Rappels RDV multi-canal (email J-2 / SMS J-1 / push J-0)
// ────────────────────────────────────────────────────────────────────────

enum AppointmentReminderChannel {
  /// J-2 via Resend (US-2074).
  email
  /// J-1 via sms.service (US-2506 mock V1 / real V3).
  sms
  /// J-0 via FCM (US-2073).
  push

  @@map("appointment_reminder_channel")
}

enum AppointmentReminderStep {
  j_minus_2
  j_minus_1
  j_0

  @@map("appointment_reminder_step")
}

enum AppointmentReminderStatus {
  sent
  failed
  skipped

  @@map("appointment_reminder_status")
}

/// US-2502 — Journal rappels RDV envoyes (cron quotidien J-2/J-1/J-0).
///
/// Idempotence absolue : `@@unique([appointmentId, channel, step])`
/// empeche envoi double si cron rejoue.
model AppointmentReminder {
  id                Int                        @id @default(autoincrement())
  appointmentId     Int                        @map("appointment_id")
  channel           AppointmentReminderChannel
  step              AppointmentReminderStep
  /// M6 round 2 — default `skipped` (vs `sent` trompeur). Le caller doit
  /// marquer explicitement `sent` après envoi réussi (defense-in-depth
  /// si bulk insert futur omet le statut).
  status            AppointmentReminderStatus  @default(skipped)
  sentAt            DateTime                   @default(now()) @map("sent_at") @db.Timestamptz()
  /// Destinataire chiffre AES-256-GCM (email pour channel=email, phone
  /// pour channel=sms, fcmToken pour channel=push).
  sentToEnc         String?                    @map("sent_to_enc")
  providerMessageId String?                    @map("provider_message_id") @db.VarChar(100)
  errorMessage      String?                    @map("error_message") @db.VarChar(500)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, channel, step], map: "appointment_reminders_appt_channel_step_key")
  @@index([appointmentId, sentAt(sort: Desc)])
  @@index([sentAt(sort: Desc)])
  @@map("appointment_reminders")
}
