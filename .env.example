# Base de données PostgreSQL
DATABASE_URL="postgresql://diabeo:password@localhost:5432/diabeo?schema=public"

# JWT RS256 (asymétrique)
# Générer avec : openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Stocker le contenu PEM avec \n pour les sauts de ligne
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# HMAC pour lookup email (index unique sans exposer email chiffré)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=""

# Chiffrement des données de santé (AES-256-GCM)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEALTH_DATA_ENCRYPTION_KEY=""

# Upstash Redis (cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OVH Object Storage (S3-compatible)
OVH_S3_ENDPOINT=""
OVH_S3_BUCKET=""
OVH_S3_ACCESS_KEY=""
OVH_S3_SECRET_KEY=""
