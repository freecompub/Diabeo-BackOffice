# Base de données PostgreSQL
DATABASE_URL="postgresql://diabeo:password@localhost:5432/diabeo?schema=public"

# JWT RS256 (asymétrique)
# Générer avec : openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Stocker le contenu PEM avec \n pour les sauts de ligne
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# HMAC pour lookup email (index unique sans exposer email chiffré)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=""

# Chiffrement des données de santé (AES-256-GCM)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEALTH_DATA_ENCRYPTION_KEY=""

# HMAC pepper pour conversation_key messagerie (US-2076 scope A, HIGH-2 round 5)
# Empêche brute-force du graphe bipartite patient↔médecin si dump DB leak.
# ⚠️ DOIT ÊTRE DISTINCT de HMAC_SECRET — chaque secret a un usage unique
# (cross-domain key reuse interdit par ANSSI RGS §B1.2).
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONVERSATION_KEY_PEPPER=""

# HMAC pepper pour anonymisation IDs dans audit metadata (US-2026 H1 round 2)
# Cas d'usage : INS collision audit (collidingUserId hashé pour éviter leak
# cross-cabinet d'identité). DPO/RSSI peut re-corréler via fonction dédiée.
# ⚠️ DOIT ÊTRE DISTINCT de HMAC_SECRET et CONVERSATION_KEY_PEPPER (RGS §B1.2).
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_PEPPER=""

# Upstash Redis (session revocation + cache)
# REQUIS en production — la revocation de session ne fonctionne pas sans Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Prefixe des cles Redis (defaut: "diabeo:prod:") — changer par env (ex: "diabeo:staging:")
# REDIS_KEY_PREFIX="diabeo:prod:"

# OVH Object Storage (S3-compatible)
# ---
# Dev local (MinIO via docker compose --profile local up):
OVH_S3_ENDPOINT="http://localhost:9000"
OVH_S3_BUCKET="diabeo-documents"
OVH_S3_ACCESS_KEY="minioadmin"
OVH_S3_SECRET_KEY="minioadmin"
OVH_S3_REGION="gra"
# ---
# Production (OVH GRA) — CHANGE THESE, never use minioadmin in staging/production:
# OVH_S3_ENDPOINT="https://s3.gra.perf.cloud.ovh.net"
# OVH_S3_BUCKET="diabeo-prod-documents"
# OVH_S3_ACCESS_KEY="<your-ovh-access-key>"
# OVH_S3_SECRET_KEY="<your-ovh-secret-key>"
# OVH_S3_REGION="gra"

# Firebase Cloud Messaging (FCM)
# Generate: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Encode: cat firebase-key.json | base64 -w 0
FIREBASE_SERVICE_ACCOUNT_KEY=""
FIREBASE_PROJECT_ID=""

# Email transactionnel (Resend)
# Dashboard: https://resend.com/api-keys
# Rétention audit logs (défaut 6 ans HDS)
AUDIT_RETENTION_YEARS="6"

RESEND_API_KEY=""
EMAIL_FROM="Diabeo <noreply@diabeo.fr>"

# Cron Bearer secret (US-2108 relances factures + cron futurs).
# Sans cette var, la route /api/cron/* retourne 503 (defense-in-depth).
# Generer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
